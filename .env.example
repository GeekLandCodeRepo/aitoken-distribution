# 服务配置
# 后端 HTTP 服务监听端口
PORT=40680
# 日志级别，默认 info；可选：debug、info、warn、error
LOG_LEVEL=info
# 是否由后端托管前端静态页面；默认 true。设为 false 时只提供 API/Relay
SERVE_WEB=true

# 数据库配置
# PostgreSQL 主机地址
DB_HOST=localhost
# PostgreSQL 端口
DB_PORT=5432
# PostgreSQL 用户名
DB_USER=aitsd
# PostgreSQL 密码
DB_PASSWORD=aitsd_pass
# PostgreSQL 数据库名
DB_NAME=aitsd
# PostgreSQL SSL 模式，本地通常为 disable
DB_SSLMODE=disable
# 数据库最大打开连接数
DB_MAX_OPEN_CONNS=100
# 数据库最大空闲连接数
DB_MAX_IDLE_CONNS=10

# Redis配置
# Redis 主机地址
REDIS_HOST=localhost
# Redis 端口
REDIS_PORT=6379
# Redis 用户名，未启用 ACL 时留空
REDIS_USERNAME=
# Redis 密码，未设置密码时留空
REDIS_PASSWORD=
# Redis 数据库编号
REDIS_DB=0

# JWT配置
# JWT 签名密钥，生产环境必须改成高强度随机字符串
JWT_SECRET=your-secret-key-change-in-production
# Access Token 有效期，单位：秒
JWT_ACCESS_EXPIRY=7200
# Refresh Token 有效期，单位：秒
JWT_REFRESH_EXPIRY=604800

# 加密配置
# ChaCha20-Poly1305 密钥，用于加密渠道 API Key；生产环境必须改成固定且保密的 32 字节字符串
CHACHA20_POLY1305_KEY=aitsd-chacha20-poly1305-key-32b

# 计费配置
# 内部额度单位换算：1 USD = 多少内部额度单位；默认 1,000,000
QUOTA_PER_USD=1000000
# 是否启用请求前预扣费；启用后会先按输入 token 预估扣费，请求结束后按实际费用结算差额
PRE_CONSUME_ENABLED=true
# 流式请求首 token 超时时间，单位：秒；默认 90，设置为 0 表示关闭 TTFT watchdog
RELAY_TTFT_TIMEOUT_SECONDS=90

# 管理员配置
# 初始化管理员邮箱；首次启动创建管理员用户时使用
ADMIN_EMAIL=admin@example.com
# 初始化管理员密码；首次启动创建管理员用户时使用，生产环境请立即修改
ADMIN_PASSWORD=Aa1234567
